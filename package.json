{
  "name": "@juun-roh/cesium-utils",
  "version": "0.4.5",
  "description": "Solve common Cesium.js challenges: combine multiple terrain sources, tag and filter entity collections, and add visual highlights.",
  "keywords": [
    "cesium",
    "cesiumjs",
    "typescript",
    "cesium-utils",
    "hybrid-terrain-provider",
    "multiple-terrain-sources",
    "terrain-switching",
    "cesium-terrain-provider",
    "entity-tagging",
    "entity-grouping",
    "entity-filtering",
    "batch-operations",
    "cesium-entity-collection",
    "primitive-collection",
    "cesium-layer-management",
    "cesium-highlight",
    "cesium-silhouette",
    "3d-tiles-highlight",
    "entity-selection",
    "3d-gis",
    "geospatial",
    "webgl",
    "virtual-globe",
    "3d-visualization"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juunie-roh/cesium-utils.git"
  },
  "homepage": "https://github.com/juunie-roh/cesium-utils#readme",
  "bugs": {
    "url": "https://github.com/juunie-roh/cesium-utils/issues"
  },
  "license": "MIT",
  "author": "Juun",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "files": [
    "dist"
  ],
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./collection": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/collection/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/collection/index.cjs"
      }
    },
    "./highlight": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/highlight/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/highlight/index.cjs"
      }
    },
    "./terrain": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/terrain/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/terrain/index.cjs"
      }
    },
    "./terrain/dev": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/terrain/dev/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/terrain/dev/index.cjs"
      }
    },
    "./dev": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/dev/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/dev/index.cjs"
      }
    },
    "./experimental": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/experimental/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/experimental/index.cjs"
      }
    },
    "./viewer": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/viewer/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/viewer/index.cjs"
      }
    }
  },
  "scripts": {
    "attw": "pnpx @arethetypeswrong/cli --pack --ignore-rules 'no-resolution'",
    "attw:quiet": "pnpx @arethetypeswrong/cli --pack --quiet --ignore-rules 'no-resolution'",
    "build": "tsup",
    "build:dev": "tsup --watch",
    "check-types": "tsc -p ./tsconfig.json --noEmit",
    "clean": "rimraf dist",
    "lint": "eslint .",
    "ci:publish": "pnpm build && pnpm publish --no-git-checks",
    "prebuild": "pnpm clean",
    "prepare": "husky",
    "prepublishOnly": "pnpm lint",
    "test": "vitest run --silent passed-only",
    "test:watch": "vitest watch --coverage",
    "test:cesium": "node scripts/test-cesium-versions.js",
    "dev": "pnpm vite"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "cesium": ">=1.133.0"
  },
  "packageManager": "pnpm@10.33.0",
  "publishConfig": {
    "access": "public"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/cz-commitlint": "^20.5.2",
    "@commitlint/format": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^4.1.5",
    "cesium": "^1.140.0",
    "eslint": "^10.2.1",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "tmp": ">=0.2.4",
      "lodash": ">=4.17.23",
      "minimatch": ">=10.2.1"
    }
  }
}
